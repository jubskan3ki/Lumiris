# Rendered by ansible/rotate-secrets.yml — DO NOT edit on the host.
# Any manual change will be overwritten on the next rotation.
ACME_EMAIL={{ acme_email }}

# Hosts (Traefik routing)
WEB_HOST={{ web_host }}
ADMIN_HOST={{ admin_host }}
MOBILE_HOST={{ mobile_host }}
API_HOST={{ api_host }}

# GHCR
GHCR_OWNER={{ ghcr_owner }}

# Database / cache
POSTGRES_USER=lumiris
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_DB=lumiris
DATABASE_URL=postgres://lumiris:{{ postgres_password }}@postgres:5432/lumiris
REDIS_URL=redis://redis:6379

# App secrets
JWT_SECRET={{ jwt_secret }}
SENTRY_DSN_API={{ sentry_dsn_api | default('') }}

# CORS
CORS_ALLOWED_ORIGINS=https://{{ web_host }},https://{{ admin_host }},https://{{ mobile_host }}
