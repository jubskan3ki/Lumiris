# Env (never bake secrets into images)
.env
.env.*
!.env.example

# VCS / CI artefacts
.git
.github
.husky
.vscode
.idea

# Tauri local artefacts
**/src-tauri/target
**/src-tauri/gen

# Tests / docs / bench (not needed at runtime)
