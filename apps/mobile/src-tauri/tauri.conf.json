{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Lumiris Mobile",
    "version": "0.1.0",
    "identifier": "fr.lumiris.mobile",
    "build": {
        "beforeDevCommand": "bun run dev:tauri",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "bun run build:tauri",
        "frontendDist": "../out"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Lumiris Vision",
                "width": 390,
                "height": 844,
                "minWidth": 360,
                "minHeight": 640,
                "resizable": true,
                "fullscreen": false,
                "center": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; img-src 'self' data: blob: https://*.tile.openstreetmap.org https://placehold.co; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' ipc: http://ipc.localhost https://*.tile.openstreetmap.org; media-src 'self' blob:"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "category": "Lifestyle",
        "shortDescription": "Lumiris - the X-Ray transparency scanner.",
        "longDescription": "LUMIRIS Mobile turns your phone into a transparency lens: scan a garment, reveal its DPP, and read its 50/30/20 IrisScore.",
        "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
        "linux": {
            "deb": {
                "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
            }
        }
    }
}
