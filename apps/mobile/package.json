        "@lumiris/utils": "workspace:*",
        "web-vitals": "^4.2.4",
        "@tauri-apps/api": "^2.1.1",
        "@vercel/analytics": "^1.6.1",
        "framer-motion": "^12.38.0",
        "lucide-react": "^0.564.0",
        "next": "^16.2.4",
        "next-themes": "^0.4.6",
        "react": "^19",
        "react-dom": "^19"
    },
    "devDependencies": {
        "@lumiris/config": "workspace:*",
        "@tailwindcss/postcss": "^4.2.0",
