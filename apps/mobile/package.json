{
    "name": "@lumiris/mobile",
    "version": "0.1.0",
    "private": true,
    "description": "LUMIRIS Mobile - mobile-optimized consumer view (Iris Scanner). Web first, Tauri-ready.",
    "scripts": {
        "dev": "next dev --port 3002",
        "dev:tauri": "next dev --port 1420",
        "build": "next build",
        "build:tauri": "BUILD_TARGET=tauri next build",
        "start": "next start --port 3002",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf .next .turbo"
    },
    "dependencies": {
        "@lumiris/core": "workspace:*",
        "@lumiris/mock-data": "workspace:*",
        "@lumiris/scoring-ui": "workspace:*",
        "@lumiris/telemetry": "workspace:*",
        "@lumiris/types": "workspace:*",
        "@lumiris/ui": "workspace:*",
        "@lumiris/utils": "workspace:*",
        "framer-motion": "^12.38.0",
        "jsqr": "^1.4.0",
        "leaflet": "^1.9.4",
        "lucide-react": "^0.564.0",
        "next": "^16.2.4",
        "react": "^19",
        "react-dom": "^19",
        "react-leaflet": "^5.0.0"
    },
    "devDependencies": {
        "@lumiris/config": "workspace:*",
        "@tailwindcss/postcss": "^4.2.0",
        "@tauri-apps/cli": "^2.1.0",
        "@types/leaflet": "^1.9.12",
        "@types/node": "^22.10.0",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9.17.0",
        "postcss": "^8.5",
        "rimraf": "^6.0.1",
        "typescript": "^5.7.3"
    }
}
