{
    "name": "@lumiris/mock-data",
    "version": "0.1.0",
    "private": true,
    "description": "LUMIRIS demo fixtures - passports textile artisanal, artisans, retoucheurs, journal. Pure data, typed against @lumiris/types.",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./journal": "./src/journal.ts",
        "./regulatory": "./src/regulatory.ts",
        "./artisans": "./src/artisans.ts",
        "./retoucheurs": "./src/retoucheurs.ts",
        "./suppliers": "./src/suppliers.ts",
        "./team": "./src/team.ts"
    },
    "scripts": {
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist .turbo"
    },
    "dependencies": {
        "@lumiris/core": "workspace:*",
        "@lumiris/types": "workspace:*",
        "@lumiris/utils": "workspace:*"
    },
    "devDependencies": {
        "@lumiris/config": "workspace:*",
        "eslint": "^9.17.0",
        "rimraf": "^6.0.1",
        "typescript": "^5.7.3"
    }
}
