{
    "name": "@lumiris/mock-data",
    "version": "0.1.0",
    "private": true,
    "description": "LUMIRIS demo fixtures — DPPs, certificates, audit log, journal, regulatory items. Pure data, typed against @lumiris/types.",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./dpp": "./src/dpp.ts",
        "./certificates": "./src/certificates.ts",
        "./audit-log": "./src/audit-log.ts",
        "./journal": "./src/journal.ts",
        "./regulatory": "./src/regulatory.ts",
        "./team": "./src/team.ts",
        "./kpi": "./src/kpi.ts",
        "./products": "./src/products.ts"
    },
    "scripts": {
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist .turbo"
    },
    "dependencies": {
        "@lumiris/types": "workspace:*"
    },
    "devDependencies": {
        "@lumiris/config": "workspace:*",
        "eslint": "^9.17.0",
        "rimraf": "^6.0.1",
        "typescript": "^5.7.3"
    }
}
