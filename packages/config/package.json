{
    "name": "@lumiris/config",
    "version": "0.1.0",
    "private": true,
    "description": "Shared LUMIRIS toolchain: ESLint, Prettier, TypeScript, Stylelint presets.",
    "type": "module",
    "exports": {
        "./eslint/base": "./eslint/base.mjs",
        "./eslint/react": "./eslint/react.mjs",
        "./eslint/next": "./eslint/next.mjs",
        "./prettier": "./prettier/prettier.config.mjs",
        "./stylelint": "./stylelint/stylelint.config.mjs",
        "./tsconfig/base.json": "./tsconfig/base.json",
        "./tsconfig/nextjs.json": "./tsconfig/nextjs.json",
        "./tsconfig/library.json": "./tsconfig/library.json"
    },
    "files": [
        "eslint",
        "prettier",
        "stylelint",
        "tsconfig",
        "types.d.ts"
    ],
    "scripts": {
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@eslint/js": "^9.17.0",
        "@next/eslint-plugin-next": "^16.2.4",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^5.2.0",
        "globals": "^15.15.0",
        "prettier-plugin-tailwindcss": "^0.6.9",
        "stylelint-config-standard": "^36.0.1",
        "stylelint-config-tailwindcss": "^1.0.0",
        "typescript-eslint": "^8.59.0"
    },
    "devDependencies": {
        "typescript": "^5.7.3"
    }
}
