{
    "name": "@lumiris/scoring-ui",
    "version": "0.1.0",
    "private": true,
    "description": "LUMIRIS visualisations bound to the 40/25/25/10 Iris scoring algorithm. Re-uses @lumiris/core; no domain logic of its own.",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./components/iris-grade": "./src/components/iris-grade.tsx",
        "./components/iris-score-card": "./src/components/iris-score-card.tsx",
        "./components/score-breakdown": "./src/components/score-breakdown.tsx",
        "./components/score-reasons-list": "./src/components/score-reasons-list.tsx",
        "./components/missing-fields-badge": "./src/components/missing-fields-badge.tsx",
        "./components/score-cap-warning": "./src/components/score-cap-warning.tsx",
        "./components/status-badge": "./src/components/status-badge.tsx",
        "./components/wardrobe": "./src/components/wardrobe.tsx",
        "./components/passport-phone-preview": "./src/components/passport-phone-preview.tsx",
        "./components/composition-list": "./src/components/composition-list.tsx",
        "./components/manufacturing-timeline": "./src/components/manufacturing-timeline.tsx",
        "./components/facture-ocr-viewer": "./src/components/facture-ocr-viewer.tsx",
        "./components/passport-header": "./src/components/passport-header.tsx",
        "./components/artisan-card": "./src/components/artisan-card.tsx",
        "./components/material-breakdown": "./src/components/material-breakdown.tsx",
        "./components/production-timeline": "./src/components/production-timeline.tsx",
        "./components/certificates-list": "./src/components/certificates-list.tsx",
        "./components/care-guide": "./src/components/care-guide.tsx",
        "./components/repairers-nearby": "./src/components/repairers-nearby.tsx",
        "./components/passport-status-banner": "./src/components/passport-status-banner.tsx",
        "./hooks/use-compute-score": "./src/hooks/use-compute-score.ts",
        "./theme/grade-color": "./src/theme/grade-color.ts"
    },
    "scripts": {
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist .turbo"
    },
    "dependencies": {
        "@lumiris/core": "workspace:*",
        "@lumiris/types": "workspace:*",
        "@lumiris/ui": "workspace:*",
        "lucide-react": "^0.564.0"
    },
    "peerDependencies": {
        "react": "^19",
        "react-dom": "^19"
    },
    "devDependencies": {
        "@lumiris/config": "workspace:*",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9.17.0",
        "rimraf": "^6.0.1",
        "typescript": "^5.7.3"
    }
}
