# ──────────────────────────────────────────────────────────────────────────
# LUMIRIS Ecosystem — environment template
# Copy to `.env` (and `.env.local` for local-only overrides). Never commit.
# ──────────────────────────────────────────────────────────────────────────

# ─── Public-facing URLs (build-time, embedded in JS bundles) ──────────────
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_MOBILE_URL=http://localhost:3002
NEXT_PUBLIC_CLIENT_URL=http://localhost:3003

# Public API base — switch to the internal service in CI/prod.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ─── Vercel Analytics & Web Vitals sampling ───────────────────────────────
NEXT_PUBLIC_VERCEL_ANALYTICS=1
NEXT_PUBLIC_WEB_VITALS_SAMPLE_RATE=1.0   # 0.1 in prod

# ─── Backend / API (placeholder until packages/api-client lands) ──────────
DATABASE_URL=postgres://lumiris:lumiris@localhost:5432/lumiris
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-me

# ─── Lighthouse CI (used by `bun run lhci`) ───────────────────────────────
LHCI_GITHUB_APP_TOKEN=

# ─── Tauri (mobile) — populated when prompt #1 is executed ────────────────
TAURI_PRIVATE_KEY=
TAURI_KEY_PASSWORD=

# ─── Telemetry (OTel + Sentry) ────────────────────────────────────────────
# OTLP/HTTP collector — Tempo in dev (via docker-compose.monitoring.yml).
# Apps fall back to console exporter when NODE_ENV !== production.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_LOG_LEVEL=info

# One Sentry project per surface — keep DSNs out of git.
SENTRY_DSN_ADMIN=
SENTRY_DSN_CLIENT=
SENTRY_DSN_WEB=
SENTRY_DSN_MOBILE=
SENTRY_DSN_API=

# Optional: pin a release tag for source-map upload + dashboards.
# SENTRY_RELEASE=
