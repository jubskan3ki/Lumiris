# Force every workspace import to resolve to the local copy of a sibling package
# rather than fetching from the registry. Bun honours this flag too.
link-workspace-packages=true

# Prefer workspace symlinks even when the local version doesn't satisfy the
# semver range — keeps `workspace:*` definitive and avoids drift mid-refactor.
prefer-workspace-packages=true

# Strict peer-deps so a package author has to declare what it expects.
strict-peer-dependencies=true
auto-install-peers=true

# Reproducible installs in CI.
save-exact=false
