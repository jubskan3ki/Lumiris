{
    "name": "@lumiris/monorepo",
    "version": "0.1.0",
    "private": true,
    "description": "LUMIRIS Ecosystem — Back-office (admin), Public Web, Mobile-optimized View. Powered by Bun + Turbo.",
    "packageManager": "bun@1.1.38",
    "engines": {
        "node": ">=20",
        "bun": ">=1.1.0"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo run dev",
        "dev:admin": "turbo run dev --filter=@lumiris/admin",
        "dev:web": "turbo run dev --filter=@lumiris/web",
        "dev:mobile": "turbo run dev --filter=@lumiris/mobile",
        "build": "turbo run build",
        "start": "turbo run start",
        "lint": "turbo run lint",
        "lint:fix": "turbo run lint -- --fix",
        "lint:css": "stylelint \"packages/ui/src/**/*.css\" \"apps/*/app/**/*.css\"",
        "lint:css:fix": "stylelint --fix \"packages/ui/src/**/*.css\" \"apps/*/app/**/*.css\"",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yaml,yml,css}\" --ignore-path .gitignore",
        "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yaml,yml,css}\" --ignore-path .gitignore",
        "typecheck": "turbo run typecheck",
        "test": "turbo run test",
        "knip": "knip",
        "knip:fix": "knip --fix",
        "lhci": "lhci autorun --config=./lighthouserc.cjs",
        "topo": "bun ./scripts/check-topology.mjs",
        "check:deps": "bunx syncpack@13 list-mismatches --config ./syncpack.config.mjs",
        "check:deps:fix": "bunx syncpack@13 fix-mismatches --config ./syncpack.config.mjs",
        "check": "bun run lint && bun run lint:css && bun run typecheck && bun run topo && bun run test",
        "fix": "bun run lint:fix && bun run lint:css:fix && bun run format",
        "clean": "turbo run clean && rimraf .turbo apps/*/.next apps/*/dist",
        "clean:all": "bun run clean && rimraf node_modules apps/*/node_modules packages/*/node_modules",
        "prepare": "husky"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.6.1",
        "@commitlint/config-conventional": "^19.6.0",
        "@lhci/cli": "^0.14.0",
        "@lumiris/config": "workspace:*",
        "@types/node": "^22.10.0",
        "eslint": "^9.17.0",
        "husky": "^9.1.7",
        "knip": "^5.39.0",
        "lint-staged": "^15.2.10",
        "prettier": "^3.4.2",
        "prettier-plugin-tailwindcss": "^0.6.9",
        "rimraf": "^6.0.1",
        "stylelint": "^16.13.2",
        "stylelint-config-standard": "^36.0.1",
        "stylelint-config-tailwindcss": "^1.0.0",
        "turbo": "^2.3.3",
        "typescript": "^5.7.3"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs}": [
            "prettier --write",
            "eslint --fix --no-warn-ignored"
        ],
        "*.css": [
            "prettier --write",
            "stylelint --fix"
        ],
        "*.{json,md,yaml,yml}": [
            "prettier --write"
        ]
    }
}
